{
  "name": "@inputforge/sandboxctl-vmm",
  "version": "0.2.0",
  "description": "sandboxctl VM provider backed by the vmm Swift binary",
  "keywords": [
    "apple",
    "macos",
    "sandbox",
    "virtualization",
    "vm"
  ],
  "homepage": "https://github.com/inputforge/sandboxctl",
  "bugs": {
    "url": "https://github.com/inputforge/sandboxctl/issues"
  },
  "license": "MIT",
  "author": "Input Forge <contact@inputforge.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inputforge/sandboxctl.git",
    "directory": "packages/vmm"
  },
  "files": [
    "dist"
  ],
  "os": [
    "darwin"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && if [ \"$(uname)\" = \"Darwin\" ]; then make -C src-native sign && cp src-native/.build/apple/Products/Release/vmm dist/vmm; fi"
  },
  "dependencies": {
    "@gcu/iso9660": "^0.1.0",
    "@inputforge/sandboxctl-providers": "0.2.0",
    "env-paths": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
