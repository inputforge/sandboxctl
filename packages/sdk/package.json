{
  "name": "@inputforge/sandbox",
  "version": "0.2.0",
  "description": "Programmatic SDK for creating and managing sandboxctl VMs",
  "keywords": [
    "sandbox",
    "virtualization",
    "vm"
  ],
  "homepage": "https://github.com/inputforge/sandboxctl",
  "bugs": {
    "url": "https://github.com/inputforge/sandboxctl/issues"
  },
  "license": "MIT",
  "author": "Input Forge <contact@inputforge.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inputforge/sandboxctl.git",
    "directory": "packages/sdk"
  },
  "files": [
