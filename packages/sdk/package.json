    "@types/ssh2": "^1.15.0",
    "typescript": "^6.0.0"
  },
  "optionalDependencies": {
    "@inputforge/sandboxctl-ec2": "0.2.0",
    "@inputforge/sandboxctl-qemu": "0.2.0",
    "@inputforge/sandboxctl-vmm": "0.2.0"
