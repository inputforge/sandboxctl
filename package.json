{
  "name": "@inputforge/create-sandbox",
  "private": true,
  "workspaces": [
    "packages/providers",
    "packages/ec2",
    "packages/qemu",
    "packages/vmm",
    "packages/cli"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
