{
  "name": "@inputforge/sandboxctl",
  "private": true,
  "workspaces": [
    "packages/providers",
    "packages/ec2",
    "packages/qemu",
    "packages/vmm",
    "packages/sdk",
    "packages/cli"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "cli": "node packages/cli/dist/index.js",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "ultracite": "^7.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@11.15.0"
}
