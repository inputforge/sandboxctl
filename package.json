    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.7.0",
    "ultracite": "^7.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
